<!--
  Network security policy for the StreamKit sample. Both relaxations are
  developer-tool concessions; tighten via <domain-config> in production.

  - cleartextTrafficPermitted="true" — allow plain http://+ws:// for
    localhost-only dev and plain-HTTP token servers.
  - <certificates src="user"/> — the actual trust path: once the user
    installs the hub's self-signed CA via the in-app "Install hub certificate"
    button (or manually from https://<host>:<port>/cert), Android validates
    the hub's TLS cert against the user CA store automatically.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>
