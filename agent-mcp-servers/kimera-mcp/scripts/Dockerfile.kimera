#
# Build Kimera-VIO itself on top of the deps-only image produced by
# Kimera-VIO's upstream Dockerfile_20_04.  Tag the deps image as
# `kimera_vio_deps` first:
#
#     cd /tmp/Kimera-VIO
#     docker build -f Dockerfile_20_04 -t kimera_vio_deps .
#     docker build -f /path/to/this/Dockerfile.kimera -t kimera_vio .

FROM kimera_vio_deps

WORKDIR /root

# Pull Kimera-VIO + its ORB vocabulary, build with the same CMake flags
# the upstream Jenkins build uses.  The binary that ends up at
# /root/Kimera-VIO/build/stereoVIOEuroc is what scripts/run_euroc.sh
# invokes.
RUN git clone https://github.com/MIT-SPARK/Kimera-VIO.git && \
    cd Kimera-VIO && \
    mkdir build && \
    cd build && \
    cmake -DCMAKE_BUILD_TYPE=Release \
          -DKIMERA_BUILD_TESTS=OFF \
          -DKIMERA_BUILD_EXAMPLES=OFF \
          .. && \
    make -j$(nproc)

# Smoke test — print the help banner during build so a broken binary
# fails the image build, not the first runtime invocation.
RUN /root/Kimera-VIO/build/stereoVIOEuroc --help 2>&1 | head -5 || true

WORKDIR /root/Kimera-VIO
